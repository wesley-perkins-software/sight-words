---
interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
}

const { title, description, canonicalUrl } = Astro.props;
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/dolch-sight-words", label: "Dolch Words" },
  { href: "/fry-sight-words", label: "Fry Words" },
  { href: "/kindergarten-sight-words", label: "Kindergarten" },
  { href: "/sight-word-games", label: "Games" },
  { href: "/sight-words-printable", label: "Printable" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style is:global>
  body {
    font-family: 'Nunito', sans-serif;
  }
@media print {
  @page {
    margin: 0.45in;
  }

  header,
  nav,
  footer,
  .ad-slot,
  .flashcard-tool,
  .no-print,
  button {
    display: none !important;
  }

  body {
    font-size: 10.5pt;
    line-height: 1.2;
    color: #000;
    background: #fff;
  }

  main {
    max-width: none !important;
    width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  main > h1 {
    display: block !important;
  }

  main > h1 {
    margin: 0 0 0.14in 0 !important;
    font-size: 18.5pt !important;
    line-height: 1.12 !important;
    color: #000 !important;
  }

  main > p,
  main > div,
  main > section,
  main > aside {
    display: none !important;
  }

  main > .word-list,
  main > section:has(.word-list) {
    display: block !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  main > section:has(.word-list) > h2 {
    display: none !important;
  }

  .word-list table {
    width: 100% !important;
    border-collapse: collapse !important;
    table-layout: fixed;
  }

  .word-list tr,
  .word-list td {
    break-inside: avoid;
    page-break-inside: avoid;
  }

  .word-list td {
    font-size: 11.5pt !important;
    line-height: 1.14 !important;
    padding: 3.5pt 5.5pt !important;
    border: 0.75pt solid #cfcfcf !important;
    color: #000 !important;
  }

  .word-list tr:nth-child(odd),
  .word-list tr:nth-child(even) {
    background: #fff !important;
  }
}
</style>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <nav class="max-w-5xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between gap-2">
          <a
            href="/"
            class="text-xl font-bold text-blue-600 hover:text-blue-700 shrink-0"
          >
            Sight Words
          </a>

          <button
            id="mobile-menu-button"
            type="button"
            class="md:hidden inline-flex min-h-12 min-w-12 items-center justify-center rounded-lg border border-gray-200 text-gray-700 hover:text-[#2563EB] hover:border-[#2563EB] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#2563EB] focus-visible:ring-offset-2 transition-colors"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Toggle navigation menu"
          >
            <svg
              id="menu-open-icon"
              class="h-6 w-6"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg
              id="menu-close-icon"
              class="hidden h-6 w-6"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <ul class="hidden md:flex md:flex-wrap gap-x-4 gap-y-1 text-sm">
            {
              navLinks.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    class="text-gray-600 hover:text-[#2563EB] font-medium"
                  >
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          id="mobile-menu"
          class="md:hidden -mx-4 mt-3 border-y border-gray-200 bg-gray-50 shadow-sm overflow-hidden max-h-0 opacity-0 pointer-events-none transition-all duration-200 ease-out"
          aria-hidden="true"
        >
          <ul class="text-base">
            {
              navLinks.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    class="min-h-12 px-4 py-3 flex items-center font-semibold text-gray-700 hover:text-[#2563EB] hover:bg-blue-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#2563EB] focus-visible:ring-inset transition-colors"
                  >
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl w-full mx-auto px-4 py-6">
      <slot />
    </main>

    <footer class="mt-auto" style="background-color: #1e293b;">
      <div class="max-w-5xl mx-auto px-4 py-8 text-sm text-white">
        <div class="flex flex-wrap gap-x-4 gap-y-1 mb-3">
          <a href="/dolch-sight-words" class="text-white hover:text-blue-300 transition-colors">Dolch Words</a>
          <a href="/fry-sight-words" class="text-white hover:text-blue-300 transition-colors">Fry Words</a>
          <a href="/kindergarten-sight-words" class="text-white hover:text-blue-300 transition-colors">Kindergarten</a>
          <a href="/sight-word-games" class="text-white hover:text-blue-300 transition-colors">Games</a>
          <a href="/sight-words-printable" class="text-white hover:text-blue-300 transition-colors">Printable</a>
        </div>
        <p class="text-slate-400">Free to use — no sign-up required.</p>
        <p class="text-slate-500 mt-1">&copy; {currentYear} Sight Words. All rights reserved.</p>
      </div>
    </footer>

    <div class="ad-slot"></div>

    <script>
      const menuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const openIcon = document.getElementById('menu-open-icon');
      const closeIcon = document.getElementById('menu-close-icon');

      if (menuButton && mobileMenu && openIcon && closeIcon) {
        const setMenuState = (isOpen) => {
          menuButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          mobileMenu.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
          mobileMenu.classList.toggle('max-h-0', !isOpen);
          mobileMenu.classList.toggle('opacity-0', !isOpen);
          mobileMenu.classList.toggle('pointer-events-none', !isOpen);
          mobileMenu.classList.toggle('max-h-96', isOpen);
          mobileMenu.classList.toggle('opacity-100', isOpen);
          openIcon.classList.toggle('hidden', isOpen);
          closeIcon.classList.toggle('hidden', !isOpen);
        };

        setMenuState(false);

        menuButton.addEventListener('click', () => {
          const expanded = menuButton.getAttribute('aria-expanded') === 'true';
          setMenuState(!expanded);
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && menuButton.getAttribute('aria-expanded') === 'true') {
            setMenuState(false);
            menuButton.focus();
          }
        });
      }
    </script>
  </body>
</html>
