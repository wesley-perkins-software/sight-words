---
import wordsData from "../data/words.json";
import { getListHref, getRouteFromSlug, majorPageLinks } from "../utils/internalLinks";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const currentPath = getRouteFromSlug(currentSlug);

const allLists = Object.values(wordsData.lists);
const relatedLists = allLists
  .filter((list) => list.slug !== currentSlug)
  .map((list) => ({
    href: getListHref(list),
    label: `${list.name} Sight Words List`,
  }))
  .filter((link) => link.href !== currentPath);

const keyPageLinks = majorPageLinks
  .filter((link) => link.slug !== currentSlug)
  .map((link) => ({
    href: getRouteFromSlug(link.slug),
    label: link.label,
  }))
  .filter((link) => link.href !== currentPath);
---

{keyPageLinks.length > 0 && (
  <section class="mt-10 pt-8 border-t border-gray-200">
    <h2 class="text-xl font-bold text-gray-800 mb-4">Helpful Next Pages</h2>
    <ul class="flex flex-wrap gap-3">
      {keyPageLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="inline-block px-4 py-2 rounded-lg bg-gray-100 text-gray-700 font-medium hover:bg-gray-200 transition-colors text-sm"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

{relatedLists.length > 0 && (
  <section class="mt-10 pt-8 border-t border-gray-200">
    <h2 class="text-xl font-bold text-gray-800 mb-4">More Sight Word Lists</h2>
    <ul class="flex flex-wrap gap-3">
      {relatedLists.map((list) => (
        <li>
          <a
            href={list.href}
            class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm"
          >
            {list.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
