---
import wordsData from "../data/words.json";
import { getRouteFromSlug, majorPageLinks } from "../utils/internalLinks";

interface Props {
  currentSlug: string;
  variant?: "chips" | "cards" | "inline";
  maxLinks?: number;
  title?: string;
}

const { currentSlug, variant = "chips", maxLinks = 4, title = "Related practice" } = Astro.props;

const majorPageLabelMap = new Map(majorPageLinks.map((link) => [link.slug, link.label]));
const listLabelMap = new Map(
  Object.values(wordsData.lists).map((list) => [list.slug, `${list.name} Sight Words`]),
);

const pageTypeRecommendations: Record<string, string[]> = {
  "dolch-pre-primer": [
    "dolch-sight-words",
    "dolch-primer",
    "kindergarten",
    "sight-word-games",
    "sight-words-printable",
  ],
  "dolch-primer": [
    "dolch-sight-words",
    "dolch-pre-primer",
    "dolch-1st-grade",
    "1st-grade",
    "sight-word-games",
  ],
  "dolch-1st-grade": [
    "dolch-sight-words",
    "dolch-primer",
    "dolch-2nd-grade",
    "1st-grade",
    "sight-words-printable",
  ],
  "dolch-2nd-grade": [
    "dolch-sight-words",
    "dolch-1st-grade",
    "dolch-3rd-grade",
    "2nd-grade",
    "sight-word-games",
  ],
  "dolch-3rd-grade": [
    "dolch-sight-words",
    "dolch-2nd-grade",
    "2nd-grade",
    "fry-sight-words",
    "sight-words-printable",
  ],
  "fry-1-100": [
    "fry-sight-words",
    "fry-101-200",
    "1st-grade",
    "sight-word-games",
    "sight-words-printable",
  ],
  "fry-101-200": [
    "fry-sight-words",
    "fry-1-100",
    "2nd-grade",
    "sight-word-games",
    "sight-words-printable",
  ],
  kindergarten: [
    "1st-grade",
    "dolch-pre-primer",
    "dolch-primer",
    "sight-word-games",
    "sight-words-printable",
  ],
  "1st-grade": [
    "kindergarten",
    "2nd-grade",
    "dolch-1st-grade",
    "fry-1-100",
    "sight-word-games",
  ],
  "2nd-grade": [
    "1st-grade",
    "dolch-2nd-grade",
    "fry-101-200",
    "sight-words-printable",
  ],
  "what-are-sight-words": [
    "dolch-sight-words",
    "fry-sight-words",
    "kindergarten",
    "sight-word-games",
  ],
  "high-frequency-words": [
    "fry-sight-words",
    "dolch-sight-words",
    "fry-1-100",
    "sight-words-printable",
  ],
  "sight-word-games": [
    "sight-words-printable",
    "kindergarten",
    "1st-grade",
    "dolch-sight-words",
  ],
  "sight-words-printable": [
    "sight-word-games",
    "dolch-sight-words",
    "fry-sight-words",
    "1st-grade",
  ],
  "dolch-sight-words": [
    "dolch-pre-primer",
    "fry-sight-words",
    "kindergarten",
    "grade-level-sight-words",
  ],
  "fry-sight-words": [
    "dolch-sight-words",
    "fry-1-100",
    "grade-level-sight-words",
    "kindergarten",
  ],
  "grade-level-sight-words": ["kindergarten", "1st-grade", "2nd-grade", "dolch-sight-words"],
};

const fallbackRecommendations = [
  "dolch-sight-words",
  "fry-sight-words",
  "sight-word-games",
  "sight-words-printable",
];

const recommendationSlugs = pageTypeRecommendations[currentSlug] ?? fallbackRecommendations;

const helpfulLinks = recommendationSlugs
  .filter((slug, index, array) => array.indexOf(slug) === index)
  .filter((slug) => slug !== currentSlug)
  .map((slug) => ({
    href: getRouteFromSlug(slug),
    label:
      majorPageLabelMap.get(slug) ||
      listLabelMap.get(slug) ||
      slug
        .replace(/-/g, " ")
        .replace(/\b\w/g, (character) => character.toUpperCase()),
  }))
  .slice(0, maxLinks);
---

{helpfulLinks.length > 0 && variant === "chips" && (
  <section class="mt-10 pt-8 border-t border-gray-200">
    <h2 class="text-xl font-bold text-gray-800 mb-4">{title}</h2>
    <ul class="flex flex-wrap gap-3">
      {helpfulLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="inline-block px-4 py-3 rounded-lg bg-gray-100 text-gray-700 font-medium hover:bg-gray-200 transition-colors text-sm"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

{helpfulLinks.length > 0 && variant === "cards" && (
  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {helpfulLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class="block px-6 py-4 rounded-xl bg-blue-50 text-blue-700 font-semibold hover:bg-blue-100 transition-colors min-h-[48px]"
        >
          <span class="block text-lg">{link.label}</span>
        </a>
      </li>
    ))}
  </ul>
)}

{helpfulLinks.length > 0 && variant === "inline" && (
  <>
    {helpfulLinks.map((link, index) => (
      <>
        <a href={link.href} class="text-blue-700 underline underline-offset-2 hover:text-blue-800 font-medium">
          {link.label}
        </a>
        {index < helpfulLinks.length - 2 && ", "}
        {index === helpfulLinks.length - 2 && " and "}
      </>
    ))}
  </>
)}
