---
import wordsData from "../data/words.json";
import { getRouteFromSlug, majorPageLinks } from "../utils/internalLinks";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const majorPageLabelMap = new Map(majorPageLinks.map((link) => [link.slug, link.label]));
const listLabelMap = new Map(
  Object.values(wordsData.lists).map((list) => [list.slug, `${list.name} Sight Words`]),
);

const pageTypeRecommendations: Record<string, string[]> = {
  "dolch-pre-primer": [
    "dolch-sight-words",
    "dolch-primer",
    "kindergarten",
    "sight-word-games",
    "sight-words-printable",
  ],
  "dolch-primer": [
    "dolch-sight-words",
    "dolch-pre-primer",
    "dolch-1st-grade",
    "1st-grade",
    "sight-word-games",
  ],
  "dolch-1st-grade": [
    "dolch-sight-words",
    "dolch-primer",
    "dolch-2nd-grade",
    "1st-grade",
    "sight-words-printable",
  ],
  "dolch-2nd-grade": [
    "dolch-sight-words",
    "dolch-1st-grade",
    "dolch-3rd-grade",
    "2nd-grade",
    "sight-word-games",
  ],
  "dolch-3rd-grade": [
    "dolch-sight-words",
    "dolch-2nd-grade",
    "2nd-grade",
    "fry-sight-words",
    "sight-words-printable",
  ],
  "fry-1-100": [
    "fry-sight-words",
    "fry-101-200",
    "1st-grade",
    "sight-word-games",
    "sight-words-printable",
  ],
  "fry-101-200": [
    "fry-sight-words",
    "fry-1-100",
    "2nd-grade",
    "sight-word-games",
    "sight-words-printable",
  ],
  kindergarten: [
    "1st-grade",
    "dolch-pre-primer",
    "dolch-primer",
    "sight-word-games",
    "sight-words-printable",
  ],
  "1st-grade": [
    "kindergarten",
    "2nd-grade",
    "dolch-1st-grade",
    "fry-1-100",
    "sight-word-games",
  ],
  "2nd-grade": [
    "1st-grade",
    "dolch-2nd-grade",
    "fry-101-200",
    "sight-words-printable",
  ],
  "what-are-sight-words": [
    "dolch-sight-words",
    "fry-sight-words",
    "kindergarten",
    "sight-word-games",
  ],
  "high-frequency-words": [
    "fry-sight-words",
    "dolch-sight-words",
    "fry-1-100",
    "sight-words-printable",
  ],
  "sight-word-games": [
    "sight-words-printable",
    "kindergarten",
    "1st-grade",
    "dolch-sight-words",
  ],
  "sight-words-printable": [
    "sight-word-games",
    "dolch-sight-words",
    "fry-sight-words",
    "1st-grade",
  ],
  "dolch-sight-words": [],
  "fry-sight-words": [],
};

const fallbackRecommendations = [
  "dolch-sight-words",
  "fry-sight-words",
  "sight-word-games",
  "sight-words-printable",
];

const recommendationSlugs = pageTypeRecommendations[currentSlug] ?? fallbackRecommendations;

const helpfulLinks = recommendationSlugs
  .filter((slug, index, array) => array.indexOf(slug) === index)
  .filter((slug) => slug !== currentSlug)
  .map((slug) => ({
    href: getRouteFromSlug(slug),
    label:
      majorPageLabelMap.get(slug) ||
      listLabelMap.get(slug) ||
      slug
        .replace(/-/g, " ")
        .replace(/\b\w/g, (character) => character.toUpperCase()),
  }))
  .slice(0, 5);
---

{helpfulLinks.length > 0 && (
  <section class="mt-10 pt-8 border-t border-gray-200">
    <h2 class="text-xl font-bold text-gray-800 mb-4">Helpful Next Pages</h2>
    <ul class="flex flex-wrap gap-3">
      {helpfulLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="inline-block px-4 py-3 rounded-lg bg-gray-100 text-gray-700 font-medium hover:bg-gray-200 transition-colors text-sm"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
