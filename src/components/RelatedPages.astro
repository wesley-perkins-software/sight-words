---
import wordsData from "../data/words.json";
import { getRouteFromSlug } from "../utils/internalLinks";

interface Props {
  currentSlug: string;
}

interface LinkItem {
  slug: string;
  href: string;
  label: string;
}

const { currentSlug } = Astro.props;
const currentPath = getRouteFromSlug(currentSlug);

const gradeListSlugs = ["kindergarten", "1st-grade", "2nd-grade"];
const dolchListSlugs = [
  "dolch-pre-primer",
  "dolch-primer",
  "dolch-1st-grade",
  "dolch-2nd-grade",
  "dolch-3rd-grade",
];
const fryListSlugs = ["fry-1-100", "fry-101-200"];

const listLabels = Object.values(wordsData.lists).reduce<Record<string, string>>((acc, list) => {
  acc[list.slug] = `${list.name} Sight Words`;
  return acc;
}, {});

const staticLinkLabels: Record<string, string> = {
  home: "Sight Words Home",
  "what-are-sight-words": "What Are Sight Words?",
  "high-frequency-words": "High Frequency Words",
  "sight-word-games": "Sight Word Games",
  "sight-words-flashcards": "Sight Words Flashcards",
  "sight-words-printable": "Printable Sight Word Lists",
  "dolch-sight-words": "Dolch Sight Words Hub",
  "fry-sight-words": "Fry Sight Words Hub",
};

const getLabel = (slug: string) => listLabels[slug] || staticLinkLabels[slug] || slug;

const getAdjacent = (slug: string, orderedSlugs: string[]) => {
  const index = orderedSlugs.indexOf(slug);

  if (index === -1) {
    return [];
  }

  return [orderedSlugs[index - 1], orderedSlugs[index + 1]].filter(Boolean) as string[];
};

const addSlugs = (bucket: string[], slugs: string[]) => {
  for (const slug of slugs) {
    if (!slug || slug === currentSlug) {
      continue;
    }

    const href = getRouteFromSlug(slug);
    if (!href || href === currentPath) {
      continue;
    }

    if (!bucket.includes(slug)) {
      bucket.push(slug);
    }
  }
};

const isDolchListPage = dolchListSlugs.includes(currentSlug);
const isFryListPage = fryListSlugs.includes(currentSlug);
const isGradeListPage = gradeListSlugs.includes(currentSlug);
const isListPage = isDolchListPage || isFryListPage || isGradeListPage;
const isHubPage = ["dolch-sight-words", "fry-sight-words"].includes(currentSlug);

const selectedSlugs: string[] = [];

if (isDolchListPage) {
  const gradeMatchByDolchSlug: Record<string, string> = {
    "dolch-pre-primer": "kindergarten",
    "dolch-primer": "kindergarten",
    "dolch-1st-grade": "1st-grade",
    "dolch-2nd-grade": "2nd-grade",
    "dolch-3rd-grade": "2nd-grade",
  };

  addSlugs(selectedSlugs, [
    "dolch-sight-words",
    ...getAdjacent(currentSlug, dolchListSlugs),
    gradeMatchByDolchSlug[currentSlug] || "kindergarten",
    "sight-words-flashcards",
  ]);
}

if (isFryListPage) {
  addSlugs(selectedSlugs, [
    "fry-sight-words",
    ...getAdjacent(currentSlug, fryListSlugs),
    "sight-words-flashcards",
    "high-frequency-words",
  ]);
}

if (isGradeListPage) {
  addSlugs(selectedSlugs, [
    "dolch-sight-words",
    "fry-sight-words",
    ...getAdjacent(currentSlug, gradeListSlugs),
    "sight-words-printable",
  ]);
}

if (isHubPage) {
  if (currentSlug === "dolch-sight-words") {
    addSlugs(selectedSlugs, [
      "dolch-pre-primer",
      "dolch-primer",
      "kindergarten",
      "sight-words-flashcards",
    ]);
  }

  if (currentSlug === "fry-sight-words") {
    addSlugs(selectedSlugs, [
      "fry-1-100",
      "fry-101-200",
      "sight-words-printable",
      "high-frequency-words",
    ]);
  }
}

if (!isListPage && !isHubPage) {
  addSlugs(selectedSlugs, [
    "dolch-sight-words",
    "fry-sight-words",
    "kindergarten",
    "sight-words-flashcards",
    "sight-words-printable",
  ]);
}

const relatedLinks: LinkItem[] = selectedSlugs.slice(0, 5).map((slug) => ({
  slug,
  href: getRouteFromSlug(slug),
  label: getLabel(slug),
}));
---

{relatedLinks.length > 0 && (
  <section class="mt-10 pt-8 border-t border-gray-200">
    <h2 class="text-xl font-bold text-gray-800 mb-4">Helpful Next Pages</h2>
    <ul class="flex flex-wrap gap-3">
      {relatedLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="inline-block px-4 py-2 rounded-lg bg-gray-100 text-gray-700 font-medium hover:bg-gray-200 transition-colors text-sm"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
