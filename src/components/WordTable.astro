---
interface Props {
  words: string[];
  listName: string;
}

const { words, listName } = Astro.props;

// Split words into rows of 3 for the table
const rows: string[][] = [];
for (let i = 0; i < words.length; i += 3) {
  rows.push(words.slice(i, i + 3));
}
---

<div class="overflow-x-auto word-list">
  <table class="w-full border-collapse text-left" aria-label={`${listName} word list`}>
    <tbody>
      {rows.map((row, i) => (
        <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
          {row.map((word) => (
            <td class="px-4 py-3 text-lg font-medium text-gray-800 border border-gray-100">{word}</td>
          ))}
          {row.length < 3 && Array.from({ length: 3 - row.length }).map(() => (
            <td class="px-4 py-3 border border-gray-100"></td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>

  <ul class="print-word-list" aria-hidden="true">
    {words.map((word) => (
      <li>{word}</li>
    ))}
  </ul>
</div>

<style>
  .print-word-list {
    display: none;
  }

  @media print {
    .word-list {
      overflow: visible !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .word-list table {
      display: none;
    }

    .print-word-list {
      display: block !important;
      -webkit-column-count: 3;
      column-count: 3;
      -webkit-column-gap: 0.22in;
      column-gap: 0.22in;
      -webkit-column-fill: balance;
      column-fill: balance;
      column-width: auto;
      list-style: none;
      margin: 0;
      padding: 0;
      orphans: 3;
      widows: 3;
    }

    .print-word-list li {
      break-inside: avoid;
      -webkit-column-break-inside: avoid;
      page-break-inside: avoid;
      padding: 0.02in 0;
      margin: 0;
      font-size: 11pt;
      line-height: 1.14;
      color: #000;
    }
  }
</style>
