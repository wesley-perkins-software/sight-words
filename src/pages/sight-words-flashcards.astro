---
import BaseLayout from "../layouts/BaseLayout.astro";
import Flashcard from "../components/Flashcard.jsx";
import FAQ from "../components/FAQ.astro";
import RelatedPages from "../components/RelatedPages.astro";
import wordsData from "../data/words.json";

const list = wordsData.lists["dolch-pre-primer"];

const faqs = [
  {
    question: "How do I use the flashcard tool?",
    answer: "Tap Next to move to the next word, Prev to go back, and Shuffle to randomize the order. Tap the blue speaker button to hear the word spoken aloud. Tap the expand icon to enter full screen mode where the word fills your entire screen."
  },
  {
    question: "Does the flashcard tool work on a phone?",
    answer: "Yes — the flashcard tool is designed mobile-first. It works on iPhone, Android, and any tablet. The full screen mode is especially useful on phones when holding the device up to a child."
  },
  {
    question: "Can I use these flashcards without an internet connection?",
    answer: "You need an internet connection to load the page initially. Once the page has loaded the flashcard tool itself works without further internet access, though the text-to-speech audio feature requires an active connection on some devices."
  },
  {
    question: "Is there a way to track my child's progress?",
    answer: "The flashcard tool shows your current position in the deck with a progress indicator. A full progress tracking feature that lets you mark words as learned is coming soon."
  }
];
---

<BaseLayout
  title="Sight Words Flashcards — Free Interactive Tool for Every List"
  description="Free interactive sight words flashcards with audio for every grade level. Practice Dolch and Fry sight words on any device with no sign-up required."
  canonicalUrl="https://placeholder.com/sight-words-flashcards"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-4">Sight Words Flashcards</h1>

  <p class="text-gray-600 leading-relaxed mb-8">
    Free interactive flashcards for every Dolch and Fry sight word list — works on any phone or tablet, no sign-up required. Tap the speaker button to hear each word spoken aloud, or tap the expand icon to enter full screen mode so you can hold the device up to your child.
  </p>

  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-800 mb-4">Try the Flashcard Tool</h2>
    <p class="text-gray-600 leading-relaxed mb-6">
      The Dolch Pre-Primer list is loaded below. Use the links further down this page to switch to any other list.
    </p>
    <Flashcard
      client:load
      words={list.words}
      listName={list.name}
    />
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-extrabold text-gray-900 mb-5 border-l-4 border-blue-600 pl-3">Choose a List to Practice</h2>

    <div class="space-y-6">
      <div>
        <h3 class="text-lg font-bold text-gray-800 mb-3">Dolch Lists</h3>
        <ul class="flex flex-wrap gap-3">
          <li><a href="/dolch-sight-words/pre-primer" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">Pre-Primer (40 words)</a></li>
          <li><a href="/dolch-sight-words/primer" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">Primer (52 words)</a></li>
          <li><a href="/dolch-sight-words/1st-grade" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">1st Grade (41 words)</a></li>
          <li><a href="/dolch-sight-words/2nd-grade" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">2nd Grade (46 words)</a></li>
          <li><a href="/dolch-sight-words/3rd-grade" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">3rd Grade (41 words)</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold text-gray-800 mb-3">Fry Lists</h3>
        <ul class="flex flex-wrap gap-3">
          <li><a href="/fry-sight-words/1-100" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">Words 1–100</a></li>
          <li><a href="/fry-sight-words/101-200" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">Words 101–200</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold text-gray-800 mb-3">Grade Level</h3>
        <ul class="flex flex-wrap gap-3">
          <li><a href="/kindergarten-sight-words" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">Kindergarten</a></li>
          <li><a href="/1st-grade-sight-words" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">1st Grade</a></li>
          <li><a href="/2nd-grade-sight-words" class="inline-block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium hover:bg-blue-100 transition-colors text-sm">2nd Grade</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-gray-800 mb-4">How to Use the Flashcard Tool Effectively</h2>
    <ul class="space-y-4 text-gray-600 leading-relaxed">
      <li>
        <strong class="text-gray-800">Keep sessions short.</strong> Five to ten minutes daily is more effective than a long session once a week. The goal is frequent, spaced repetition — that's what builds automatic recognition.
      </li>
      <li>
        <strong class="text-gray-800">Use Shuffle regularly.</strong> If your child always sees words in the same order, they start anticipating the next word instead of actually reading it. Shuffling keeps practice honest.
      </li>
      <li>
        <strong class="text-gray-800">Tap the speaker to hear the word.</strong> For younger children or words your child is uncertain about, hearing the word spoken aloud reinforces the connection between the written and spoken form.
      </li>
      <li>
        <strong class="text-gray-800">Focus on words your child misses.</strong> When your child hesitates on a word, note it and come back to it. Use the Prev button to return immediately, then revisit those words again at the start of the next session.
      </li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-gray-800 mb-4">Full Screen Mode</h2>
    <p class="text-gray-600 leading-relaxed mb-4">
      Tap the expand icon in the bottom corner of the flashcard to enter full screen mode. In full screen mode, the word fills your entire screen in large text — perfect for holding your phone or tablet up to your child so they can read the word clearly from a short distance.
    </p>
    <p class="text-gray-600 leading-relaxed">
      Full screen mode is especially useful during sessions where you're quizzing your child rather than practicing together. Hold up the device, call out "what does this say?", and move to the next word with a tap. It turns flashcard practice into a quick, engaging game.
    </p>
  </section>

  <div class="no-print">
    <FAQ faqs={faqs} />
  </div>

  <div class="no-print">
    <RelatedPages currentSlug="sight-words-flashcards" />
  </div>
</BaseLayout>
