---
import BaseLayout from "../layouts/BaseLayout.astro";
import Flashcard from "../components/Flashcard.jsx";
import FAQ from "../components/FAQ.astro";
import wordsData from "../data/words.json";
import { getListHref } from "../utils/internalLinks";

const dolchPrePrimer = wordsData.lists["dolch-pre-primer"];
const dolchPrimer = wordsData.lists["dolch-primer"];
const dolchFirstGrade = wordsData.lists["dolch-1st-grade"];
const dolchSecondGrade = wordsData.lists["dolch-2nd-grade"];
const dolchThirdGrade = wordsData.lists["dolch-3rd-grade"];
const fry1100 = wordsData.lists["fry-1-100"];
const fry101200 = wordsData.lists["fry-101-200"];
const kindergarten = wordsData.lists["kindergarten"];
const gradeOne = wordsData.lists["1st-grade"];
const gradeTwo = wordsData.lists["2nd-grade"];

const flashcardLists = [
  { key: "dolch-pre-primer", label: "Pre-Primer",  group: "Dolch",    name: dolchPrePrimer.name,   grade: dolchPrePrimer.grade,   wordCount: dolchPrePrimer.wordCount,   words: dolchPrePrimer.words },
  { key: "dolch-primer",     label: "Primer",      group: "Dolch",    name: dolchPrimer.name,      grade: dolchPrimer.grade,      wordCount: dolchPrimer.wordCount,      words: dolchPrimer.words },
  { key: "dolch-1st-grade",  label: "1st Grade",   group: "Dolch",    name: dolchFirstGrade.name,  grade: dolchFirstGrade.grade,  wordCount: dolchFirstGrade.wordCount,  words: dolchFirstGrade.words },
  { key: "dolch-2nd-grade",  label: "2nd Grade",   group: "Dolch",    name: dolchSecondGrade.name, grade: dolchSecondGrade.grade, wordCount: dolchSecondGrade.wordCount, words: dolchSecondGrade.words },
  { key: "dolch-3rd-grade",  label: "3rd Grade",   group: "Dolch",    name: dolchThirdGrade.name,  grade: dolchThirdGrade.grade,  wordCount: dolchThirdGrade.wordCount,  words: dolchThirdGrade.words },
  { key: "fry-1-100",        label: "Fry 1–100",   group: "Fry",      name: fry1100.name,          grade: fry1100.grade,          wordCount: fry1100.wordCount,          words: fry1100.words },
  { key: "fry-101-200",      label: "Fry 101–200", group: "Fry",      name: fry101200.name,        grade: fry101200.grade,        wordCount: fry101200.wordCount,        words: fry101200.words },
  { key: "kindergarten",     label: "Kindergarten",group: "By Grade", name: kindergarten.name,     grade: kindergarten.grade,     wordCount: kindergarten.wordCount,     words: kindergarten.words },
  { key: "1st-grade",        label: "1st Grade",   group: "By Grade", name: gradeOne.name,         grade: gradeOne.grade,         wordCount: gradeOne.wordCount,         words: gradeOne.words },
  { key: "2nd-grade",        label: "2nd Grade",   group: "By Grade", name: gradeTwo.name,         grade: gradeTwo.grade,         wordCount: gradeTwo.wordCount,         words: gradeTwo.words },
];

const dolchBrowseItems = [
  { name: "Pre-Primer", href: "/dolch-sight-words/pre-primer", details: `${dolchPrePrimer.wordCount} words · Pre-K` },
  { name: "Primer", href: "/dolch-sight-words/primer", details: `${dolchPrimer.wordCount} words · Kindergarten` },
  { name: "1st Grade", href: "/dolch-sight-words/1st-grade", details: `${dolchFirstGrade.wordCount} words · 1st Grade` },
  { name: "2nd Grade", href: "/dolch-sight-words/2nd-grade", details: `${dolchSecondGrade.wordCount} words · 2nd Grade` },
  { name: "3rd Grade", href: "/dolch-sight-words/3rd-grade", details: `${dolchThirdGrade.wordCount} words · 3rd Grade` },
];

const fryBrowseItems = [
  { name: "Fry Words 1–100", href: getListHref(fry1100), details: `${fry1100.wordCount} words · Kindergarten / 1st Grade` },
  { name: "Fry Words 101–200", href: getListHref(fry101200), details: `${fry101200.wordCount} words · 1st / 2nd Grade` },
];

const faqs = [
  {
    question: "What are sight words?",
    answer:
      "Sight words are high-frequency words that children are taught to recognize instantly — without sounding them out. Words like 'the', 'said', 'was', and 'they' appear so often in books that recognizing them on sight dramatically speeds up reading fluency. Most reading programs begin teaching sight words in pre-K and kindergarten.",
  },
  {
    question: "What are the most common sight words for beginners?",
    answer:
      "The most common beginner sight words include: the, a, and, is, it, in, was, he, she, for, on, are, as, with, his, they, at, be, this, from. These appear in almost every children's book and are the foundation of early reading. The Dolch pre-primer list is the standard starting point for pre-K and kindergarten learners.",
  },
  {
    question: "What is the difference between Dolch and Fry sight words?",
    answer:
      "Dolch words are a list of 220 common words compiled by Edward Dolch in 1948, organized by grade level from pre-primer through 3rd grade. Fry words are a more modern list of 1,000 words compiled by Dr. Edward Fry, ranked by how frequently they appear in printed text. Both lists are widely used in schools — Dolch is more common in early grades, while Fry extends further for 2nd grade and beyond.",
  },
  {
    question: "How many sight words should my kindergartner know?",
    answer:
      "Most kindergartners are expected to recognize between 20 and 50 sight words by the end of the school year. The Dolch pre-primer list (40 words) and primer list (52 words) are the standard targets. By the end of 1st grade, most children should know all 220 Dolch words.",
  },
  {
    question: "Are these flashcards free to use and print?",
    answer:
      "Yes — everything on this site is completely free. No sign-up, no subscription, no app to download. The flashcards work in your browser on any phone or tablet. You can also print the word lists directly from any list page using your browser's print function.",
  },
  {
    question: "How do I use these flashcards?",
    answer:
      "Tap the speaker icon to hear the word spoken aloud. Use the Next and Previous buttons to move through the list. Tap Shuffle any time to practice in a random order. The flashcard is designed to be held up to your child on your phone — large text, simple layout. Five minutes of daily practice is more effective than longer, less frequent sessions.",
  },
];
---

<BaseLayout
  title="Free Sight Words Flashcards, Lists & Printables — Dolch & Fry"
  description="Free sight word flashcards, printable word lists, and audio practice for pre-K through 3rd grade. Covers all Dolch and Fry sight words. No sign-up needed."
  canonicalUrl="https://placeholder.com"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-4">Free Sight Words Flashcards & Word Lists</h1>

  <p class="text-gray-600 leading-relaxed mb-8">
    Practice Dolch and Fry sight words with free interactive flashcards — audio
    included, no sign-up required. Covers every grade level from pre-K through
    3rd grade. Works on your phone. Print any list in seconds.
  </p>

  <div id="flashcard-tool">
    <Flashcard
      client:load
      lists={flashcardLists}
    />
  </div>

  <section class="mt-10">
    <h2 class="text-2xl font-extrabold text-gray-900 mb-5 border-l-4 border-blue-600 pl-3">Browse by Grade Level</h2>
    <ul class="flex flex-wrap gap-4">
      <li>
        <a
          href="/kindergarten-sight-words"
          class="inline-block px-6 py-3 rounded-xl bg-blue-50 text-blue-700 font-semibold hover:bg-blue-100 transition-colors text-base"
        >
          Kindergarten Sight Words
        </a>
      </li>
      <li>
        <a
          href="/1st-grade-sight-words"
          class="inline-block px-6 py-3 rounded-xl bg-blue-50 text-blue-700 font-semibold hover:bg-blue-100 transition-colors text-base"
        >
          1st Grade Sight Words
        </a>
      </li>
      <li>
        <a
          href="/2nd-grade-sight-words"
          class="inline-block px-6 py-3 rounded-xl bg-blue-50 text-blue-700 font-semibold hover:bg-blue-100 transition-colors text-base"
        >
          2nd Grade Sight Words
        </a>
      </li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-extrabold text-gray-900 border-l-4 border-blue-600 pl-3">Dolch Sight Words</h2>
    <a
      href="/dolch-sight-words"
      class="mt-2 inline-flex items-center min-h-[48px] px-2 text-sm font-semibold text-blue-700 hover:text-blue-800 underline underline-offset-2"
    >
      Explore Dolch sight words →
    </a>
    <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {dolchBrowseItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block px-6 py-4 rounded-xl bg-blue-50 text-blue-700 font-semibold hover:bg-blue-100 transition-colors"
          >
            <span class="block text-lg">{item.name}</span>
            <span class="block text-sm font-normal text-blue-500 mt-1">{item.details}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-extrabold text-gray-900 border-l-4 border-blue-600 pl-3">Fry Sight Words</h2>
    <a
      href="/fry-sight-words"
      class="mt-2 inline-flex items-center min-h-[48px] px-2 text-sm font-semibold text-blue-700 hover:text-blue-800 underline underline-offset-2"
    >
      Explore Fry sight words →
    </a>
    <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {fryBrowseItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block px-6 py-4 rounded-xl bg-blue-50 text-blue-700 font-semibold hover:bg-blue-100 transition-colors"
          >
            <span class="block text-lg">{item.name}</span>
            <span class="block text-sm font-normal text-blue-500 mt-1">{item.details}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-gray-800 mb-3">
      Sight Word Practice Tips
    </h2>
    <p class="text-gray-600 leading-relaxed">
      Tap the speaker icon to hear the word read aloud, then use Next and
      Previous to move through the list. Hit Shuffle any time to practice in a
      random order. Five minutes a day beats one long session — short, daily
      sight word practice is what actually builds fluency.
    </p>
  </section>

  <FAQ faqs={faqs} />

</BaseLayout>
